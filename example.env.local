# Backend API base (used by auth + axios client)
NEXT_PUBLIC_API_URL=http://localhost:5001/api/v1

# Backend API base (used by direct fetch calls in some dashboard/auth modules)
NEXT_PUBLIC_BACKEND_URL=http://localhost:5001/api/v1

# App URL for NextAuth
NEXTAUTH_URL=http://localhost:3000

# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=replace_with_a_secure_random_secret

# Optional websocket endpoint
NEXT_PUBLIC_SOCKET_URL=http://localhost:5001